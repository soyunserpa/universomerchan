{
  "name": "universo-merchan",
  "version": "1.0.0",
  "private": true,
  "description": "Universo Merchan — Tienda de merchandising personalizado con integración API Midocean",
  "scripts": {
    "dev": "next dev --port 3000",
    "dev:admin": "ADMIN_MODE=true next dev --port 3001",
    "build": "next build",
    "start": "next start --port 3000",
    "start:admin": "ADMIN_MODE=true next start --port 3001",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "sync:full": "tsx --env-file=.env scripts/initial-sync.ts",
    "sync:stock": "tsx --env-file=.env scripts/sync-stock.ts",
    "sync:orders": "tsx --env-file=.env scripts/sync-orders.ts",
    "sync:print": "tsx --env-file=.env src/scripts/sync-print.ts",
    "sync:cleanup": "tsx scripts/cleanup-catalog.ts",
    "admin:create": "tsx --env-file=.env scripts/create-admin.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/react": "^3.0.159",
    "@neondatabase/serverless": "^0.9.0",
    "@next/third-parties": "^16.2.1",
    "@react-pdf/renderer": "^3.4.0",
    "@stripe/stripe-js": "^4.0.0",
    "@types/pdfkit": "^0.17.6",
    "ai": "^6.0.157",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.0",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.33.0",
    "fabric": "^6.0.0",
    "imagetracerjs": "^1.2.6",
    "ioredis": "^5.4.0",
    "jose": "^5.6.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.400.0",
    "next": "^14.2.0",
    "node-cron": "^3.0.3",
    "openai": "^6.33.0",
    "pdfkit": "^0.18.0",
    "postgres": "^3.4.0",
    "posthog-js": "^1.371.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "resend": "^3.5.0",
    "sharp": "^0.33.0",
    "ssh2": "^1.17.0",
    "stripe": "^16.12.0",
    "svg-to-pdfkit": "^0.1.8",
    "tailwind-merge": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.24.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
